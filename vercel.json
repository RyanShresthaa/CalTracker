{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm run db:generate",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "workspace": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "workspace": "backend",
      "routePrefix": "/_/backend",
      "framework": "express",
      "installCommand": "npm install && npx prisma generate",
      "buildCommand": "npx prisma generate",
      "preDeployCommand": "npx prisma generate"
    }
  }
}
