{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "workspace": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "workspace": "backend",
      "routePrefix": "/_/backend",
      "framework": "express",
      "installCommand": "npm install",
      "buildCommand": "npm run vercel-build"
    }
  }
}
