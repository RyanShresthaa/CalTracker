DATABASE_URL="postgresql://postgres:password@localhost:5432/calorie_tracker"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
PORT=5000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# USDA FoodData Central (free key: https://fdc.nal.usda.gov/api-key-signup.html)
# Falls back to DEMO_KEY if unset — fine for development, get your own key for production.
USDA_API_KEY="DEMO_KEY"

# Open Food Facts — no API key required (https://world.openfoodfacts.org)

# Email (for forgot password - optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
