# Optional: set when opening the app from another device on your network (e.g. phone PWA)
# Usually NOT needed — use `npm run preview -- --host` and leave VITE_API_URL unset (Vite proxies /api).
# Example direct API URL: VITE_API_URL=http://192.168.1.10:5000/api
# VITE_API_URL=

# Vercel production only (uses /_/backend/api route):
# VITE_VERCEL_API=1
